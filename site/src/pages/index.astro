---
import {sanityClient, urlFor} from '../lib/sanity'

const realizations = await sanityClient.fetch(`
  *[_type == "realization" && defined(slug.current)] | order(_createdAt desc) {
    _id,
    title,
    category,
    description,
    image,
    "slug": slug.current
  }
`)
---

<!doctype html>
<html lang="pl">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width" />
	<title>Astro + Sanity test</title>
</head>

<body>
<main class="page">
	<section class="hero">
		<p style="color: red; font-size: 24px;">
			BUILD TEST 123
		</p>
		<p class="eyebrow">Test projektu</p>
		<h1>Realizacje z panelu Sanity</h1>
		<p>
			Te karty nie są wpisane ręcznie w HTML. Są pobierane z zewnętrznego
			panelu administracyjnego.
		</p>
	</section>

	<section class="section">
		<div class="section-header">
			<p class="eyebrow">Portfolio</p>
			<h2>Ostatnie realizacje</h2>
		</div>

		<div class="grid">
			{realizations.map((item: any) => (
				<a class="card" href={`/realizacje/${item.slug}/`}>
					{item.image && (
						<img
							src={urlFor(item.image).width(900).height(650).quality(75).auto('format').url()}
							alt={item.title}
							loading="lazy"
						/>
					)}

					<div class="card-body">
						<span>{item.category}</span>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</div>
				</a>
			))}
		</div>
	</section>
</main>
</body>
</html>

<style>
	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		font-family:
			Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		background: #111;
		color: #f5f1ea;
	}

	.page {
		min-height: 100vh;
	}

	.hero {
		padding: 96px 24px 64px;
		max-width: 1100px;
		margin: 0 auto;
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #d8b56d;
		text-transform: uppercase;
		letter-spacing: 0.14em;
		font-size: 13px;
		font-weight: 700;
	}

	h1 {
		max-width: 760px;
		margin: 0 0 20px;
		font-size: clamp(42px, 7vw, 82px);
		line-height: 0.95;
	}

	.hero p:last-child {
		max-width: 620px;
		color: #c9c1b6;
		font-size: 18px;
		line-height: 1.7;
	}

	.section {
		padding: 32px 24px 96px;
		max-width: 1100px;
		margin: 0 auto;
	}

	.section-header {
		margin-bottom: 28px;
	}

	h2 {
		margin: 0;
		font-size: clamp(28px, 4vw, 44px);
	}

	.grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 22px;
	}

	.card {
		overflow: hidden;
		border: 1px solid rgba(216, 181, 109, 0.25);
		border-radius: 24px;
		background: #1a1a1a;
		box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
		display: block;
		color: inherit;
		text-decoration: none;
	}

	.card img {
		display: block;
		width: 100%;
		height: 230px;
		object-fit: cover;
	}

	.card-body {
		padding: 22px;
	}

	.card span {
		display: inline-block;
		margin-bottom: 12px;
		color: #d8b56d;
		font-size: 13px;
		text-transform: uppercase;
		letter-spacing: 0.1em;
	}

	.card h3 {
		margin: 0 0 10px;
		font-size: 22px;
	}

	.card p {
		margin: 0;
		color: #c9c1b6;
		line-height: 1.6;
	}

	@media (max-width: 900px) {
		.grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	@media (max-width: 640px) {
		.hero {
			padding-top: 72px;
		}

		.grid {
			grid-template-columns: 1fr;
		}
	}
</style>