---
import {sanityClient, urlFor} from '../../lib/sanity'

const realizations = await sanityClient.fetch(`
  *[_type == "realization" && defined(slug.current)] | order(_createdAt desc) {
    _id,
    title,
    category,
    description,
    image,
    "slug": slug.current
  }
`)
---

<!doctype html>
<html lang="pl">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Realizacje</title>
</head>

<body>
<main class="page">
    <section class="hero">
        <a class="back-link" href="/">← Strona główna</a>
        <p class="eyebrow">Portfolio</p>
        <h1>Wszystkie realizacje</h1>
        <p>Lista projektów dodanych przez panel administracyjny Sanity.</p>
    </section>

    <section class="section">
        <div class="grid">
          {realizations.map((item: any) => (
                  <a class="card" href={`/realizacje/${item.slug}/`}>
                    {item.image && (
                            <img
                                    src={urlFor(item.image).width(900).height(650).quality(75).auto('format').url()}
                                    alt={item.title}
                                    loading="lazy"
                            />
                    )}

                      <div class="card-body">
                          <span>{item.category}</span>
                          <h3>{item.title}</h3>
                          <p>{item.description}</p>
                      </div>
                  </a>
          ))}
        </div>
    </section>
</main>
</body>
</html>

<style>
    * {
        box-sizing: border-box;
    }

    body {
        margin: 0;
        font-family:
                Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: #111;
        color: #f5f1ea;
    }

    .page {
        min-height: 100vh;
    }

    .hero,
    .section {
        max-width: 1100px;
        margin: 0 auto;
        padding-inline: 24px;
    }

    .hero {
        padding-top: 72px;
        padding-bottom: 48px;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 32px;
        color: #d8b56d;
        text-decoration: none;
    }

    .eyebrow {
        margin: 0 0 12px;
        color: #d8b56d;
        text-transform: uppercase;
        letter-spacing: 0.14em;
        font-size: 13px;
        font-weight: 700;
    }

    h1 {
        max-width: 760px;
        margin: 0 0 20px;
        font-size: clamp(42px, 7vw, 82px);
        line-height: 0.95;
    }

    .hero p:last-child {
        max-width: 620px;
        color: #c9c1b6;
        font-size: 18px;
        line-height: 1.7;
    }

    .section {
        padding-bottom: 96px;
    }

    .grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
    }

    .card {
        display: block;
        overflow: hidden;
        color: inherit;
        text-decoration: none;
        border: 1px solid rgba(216, 181, 109, 0.25);
        border-radius: 24px;
        background: #1a1a1a;
        box-shadow: 0 24px 70px rgba(0, 0, 0, 0.28);
        transition:
                transform 0.25s ease,
                border-color 0.25s ease;
    }

    .card:hover {
        transform: translateY(-4px);
        border-color: rgba(216, 181, 109, 0.65);
    }

    .card img {
        display: block;
        width: 100%;
        height: 230px;
        object-fit: cover;
    }

    .card-body {
        padding: 22px;
    }

    .card span {
        display: inline-block;
        margin-bottom: 12px;
        color: #d8b56d;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .card h3 {
        margin: 0 0 10px;
        font-size: 22px;
    }

    .card p {
        margin: 0;
        color: #c9c1b6;
        line-height: 1.6;
    }

    @media (max-width: 900px) {
        .grid {
            grid-template-columns: 1fr 1fr;
        }
    }

    @media (max-width: 640px) {
        .grid {
            grid-template-columns: 1fr;
        }
    }
</style>